function MetodologiaSection() {
  const [op, setOp] = useState(null);
  const panels = [{
    id: 'fontes',
    t: 'Fontes de dados',
    txt: ['As chegadas internacionais (Brasil e Rio de Janeiro) são publicadas mensalmente pela Embratur. As taxas de câmbio (USD, EUR, ARS, CLP e UYU frente ao BRL) são médias mensais do Banco Central do Brasil.', 'Preços do petróleo Brent e combustível QAV (USD/galão) são obtidos de fontes de mercado. Dados de oferta aérea — voos, assentos e rotas internacionais — referem-se ao Aeroporto do Galeão (GIG) e são publicados pela ANAC.', `A série histórica cobre mensalmente de janeiro/2018 a ${fmtM(last_update)}.`]
  }, {
    id: 'modelos',
    t: 'Modelos utilizados',
    txt: ['A Função de Correlação Cruzada (CCF) identifica com quantos meses de defasagem cada variável econômica se associa às chegadas internacionais.', 'O teste ADF (Dickey-Fuller Aumentado) verifica a estacionariedade das séries antes de qualquer modelagem — séries não-estacionárias precisam de diferenciação para evitar correlações espúrias.', 'O modelo preditivo principal será o OLS com Defasagens Distribuídas (referência: Tavares, 2024), incorporando os lags identificados pela CCF. O benchmark é o SARIMA. Métricas: MAPE, MAE e RMSE.']
