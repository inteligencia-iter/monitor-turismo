function detectAnomalies(key) {
  const covidMes = new Set(['2020-03','2020-04','2020-05','2020-06','2020-07','2020-08','2020-09','2020-10','2020-11','2020-12','2021-01','2021-02','2021-03','2021-04','2021-05','2021-06','2021-07','2021-08','2021-09','2021-10','2021-11','2021-12']);
  const filtered = series.filter(d => !covidMes.has(d.mes) && d[key] != null && !isNaN(d[key]));
  if (filtered.length < 5) return [];
  const vals = filtered.map(d => d[key]);
  const mean = vals.reduce((a,b)=>a+b,0)/vals.length;
  const std = Math.sqrt(vals.reduce((a,b)=>a+(b-mean)**2,0)/vals.length);
  if (std < 1e-9) return [];
  return series.filter(d => !covidMes.has(d.mes) && d[key] != null && Math.abs((d[key]-mean)/std) > 2.8)
    .sort((a,b)=>Math.abs((b[key]-mean)/std)-Math.abs((a[key]-mean)/std))
    .slice(0,3);
}
const CORR_INSIGHT = {
  usd_brl: 'Dólar mais caro significa que o turista americano (ou qualquer origem que usa dólar como referência) precisa de menos dólares para viajar ao Brasil — o país fica "mais barato" para ele. Essa correlação captura esse efeito: real desvalorizado pode estimular chegadas, especialmente de origens de renda alta. O efeito é moderado porque desvalorização do real também pode sinalizar instabilidade econômica, que contrabalança o atrativo.',
  eur_brl: 'Euro valorizado amplia o poder de compra do turista europeu no Brasil: hotel, restaurante e passeios custam menos em euros. É um incentivo direto à viagem. O efeito tende a ser mais robusto para europeus com renda mais alta, onde o custo da passagem já é o principal obstáculo — uma vez superado, a vantagem cambial acelera a decisão.',
  ars_brl: 'Este é o par mais complexo da análise. Em teoria, peso mais forte → Brasil mais barato para argentinos → mais chegadas. Na prática, crises cambiais na Argentina (hiperinflação de 2019 e 2023, controles de capital) fizeram o ARS/BRL desabar enquanto as chegadas cresciam — possivelmente por motivos não-cambiais, como diferença de custo de vida e demanda reprimida pós-COVID. O sinal e a defasagem devem ser interpretados com cautela extra.',
  clp_brl: 'Peso chileno mais forte torna o Brasil relativamente mais acessível para chilenos. A correlação é moderada porque a proximidade geográfica reduz o peso do câmbio na decisão de viagem — o custo da passagem representa parcela menor do orçamento. Fatores como oferta de voos diretos e sazonalidade tendem a ser mais determinantes para essa origem.',
  uyu_brl: 'Peso uruguaio valorizado favorece viagens ao Brasil — lógica similar às demais origens da América do Sul. O efeito é limitado pelo volume relativamente menor de visitantes e pelo fato de que o Uruguai é um país próximo, onde o câmbio pesa menos na decisão de viagem do que em origens intercontinentais.',
  brent_close: 'O petróleo é a matéria-prima central para a aviação. Brent mais caro → custo de querosene (QAV) sobe → companhias aéreas repassam em tarifas ou reduzem capacidade → turistas pagam mais ou não encontram voos → chegadas caem. O lag identifica em quantos meses esse efeito se materializa nas chegadas ao Rio.',
  brent_high: 'A máxima diária do Brent captura picos de volatilidade — momentos de choque externo (guerra, corte de produção da OPEP) que criam incerteza no planejamento das aéreas. Efeito econômico similar ao fechamento, mas a máxima é mais sensível a choques abruptos do que à média do mês.',
  qav: 'QAV (querosene de aviação) é o custo operacional mais relevante das aéreas — representa 25-30% dos custos totais. Quando o QAV sobe, as companhias aéreas podem reduzir rotas, aumentar tarifas ou ambos. Isso afeta diretamente a acessibilidade do Rio como destino internacional.',
  voos: 'Número de voos é a variável de oferta mais direta: sem voo, o turista não chega. A correlação positiva e forte é esperada — quando há mais operações internacionais no Galeão, há mais turistas chegando. Essa variável capta tanto expansão de novas rotas quanto aumento de frequências em rotas existentes.',
  assentos: 'Assentos disponíveis nos voos internacionais que chegam ao Galeão é a variável de capacidade instalada. Mais assentos = mais turistas podem viajar. A relação é real e direta: as aéreas colocam capacidade e os turistas a ocupam. Isso não é coincidência estatística — é a estrutura física do turismo aéreo.',
  rotas: 'Número de rotas internacionais indica quantas origens estão conectadas ao Galeão. Mais rotas = mais mercados emissores ativados = mais possibilidade de chegadas diversificadas. A expansão de rotas tende a gerar demanda nos mercados recém-conectados ao longo dos meses seguintes.',
};
